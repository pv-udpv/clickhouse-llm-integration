# ClickHouse LLM Integration - Environment Configuration
# Version: 0.4.0 | Last Updated: 2026-03-23
#
# Quick Start:
# 1. Copy: cp config/.env.example config/.env
# 2. Add your API keys (see REQUIRED KEYS section)
# 3. Adjust settings as needed
#
# Full documentation: config/ENV_REFERENCE.md

# ═══════════════════════════════════════════════════════════════
# REQUIRED API KEYS
# ═══════════════════════════════════════════════════════════════

OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ORG_ID=

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

PERPLEXITY_API_KEY=pplx-your-perplexity-key-here

HUGGINGFACE_API_KEY=hf_your-huggingface-key-here

# ═══════════════════════════════════════════════════════════════
# CLICKHOUSE CONNECTION
# ═══════════════════════════════════════════════════════════════

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# OR use DSN (alternative)
# CLICKHOUSE_DSN=clickhouse://default@localhost:9000/default

# Connection Pool
CLICKHOUSE_POOL_SIZE=10
CLICKHOUSE_POOL_TIMEOUT=30
CLICKHOUSE_QUERY_TIMEOUT=300
CLICKHOUSE_MAX_MEMORY_USAGE=10000000000
CLICKHOUSE_COMPRESSION=lz4

# SSL/TLS
CLICKHOUSE_SECURE=false
CLICKHOUSE_VERIFY=true

# ═══════════════════════════════════════════════════════════════
# MINDSDB
# ═══════════════════════════════════════════════════════════════

MINDSDB_HOST=http://localhost
MINDSDB_PORT=47334
MINDSDB_USER=mindsdb
MINDSDB_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# REDIS CACHE
# ═══════════════════════════════════════════════════════════════

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# Cache TTL (seconds)
REDIS_DEFAULT_TTL=3600
REDIS_EMBEDDING_TTL=86400
REDIS_LLM_TTL=3600

# ═══════════════════════════════════════════════════════════════
# EMBEDDING MODELS
# ═══════════════════════════════════════════════════════════════

HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_EMBEDDING_DIMENSIONS=384

PPLX_EMBEDDING_MODEL=pplx-embed-v1-0.6b
PPLX_EMBEDDING_DIMENSIONS=1024

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
SENTENCE_TRANSFORMER_DEVICE=cpu

# ═══════════════════════════════════════════════════════════════
# LLM MODELS
# ═══════════════════════════════════════════════════════════════

OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000
OPENAI_TOP_P=1.0
OPENAI_FREQUENCY_PENALTY=0.0
OPENAI_PRESENCE_PENALTY=0.0

CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=1000
CLAUDE_TEMPERATURE=0.7
CLAUDE_TOP_P=1.0
CLAUDE_TOP_K=40

PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-chat
PERPLEXITY_MAX_TOKENS=1000
PERPLEXITY_TEMPERATURE=0.7

# ═══════════════════════════════════════════════════════════════
# RETRY & RATE LIMITING
# ═══════════════════════════════════════════════════════════════

MAX_RETRIES=3
RETRY_BACKOFF=1.0
RETRY_BACKOFF_MAX=60
RETRY_BACKOFF_MULTIPLIER=2
RETRY_JITTER=true

REQUEST_TIMEOUT=30
EMBEDDING_TIMEOUT=30
LLM_TIMEOUT=60
STREAM_TIMEOUT=120

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

OPENAI_RPM=3000
OPENAI_TPM=250000
ANTHROPIC_RPM=2000
PERPLEXITY_RPM=600
HUGGINGFACE_RPM=1000

# ═══════════════════════════════════════════════════════════════
# CACHING
# ═══════════════════════════════════════════════════════════════

CACHE_TYPE=memory
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600
CACHE_KEY_PREFIX=clickhouse_llm
CACHE_KEY_VERSION=v1

MEMORY_CACHE_MAX_SIZE=1000
MEMORY_CACHE_EVICTION=lru

FILE_CACHE_DIR=/tmp/llm-cache
FILE_CACHE_MAX_SIZE=10000
FILE_CACHE_COMPRESSION=true

# ═══════════════════════════════════════════════════════════════
# BATCH PROCESSING
# ═══════════════════════════════════════════════════════════════

BATCH_SIZE=50
BATCH_MAX_WORKERS=10
BATCH_RETRY_ATTEMPTS=3
BATCH_PROGRESS_INTERVAL=10
BATCH_CHECKPOINT_ENABLED=true
BATCH_CHECKPOINT_INTERVAL=100

# ═══════════════════════════════════════════════════════════════
# LOGGING & MONITORING
# ═══════════════════════════════════════════════════════════════

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/clickhouse-llm/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

LOG_INCLUDE_TIMESTAMP=true
LOG_INCLUDE_CALLER=true
LOG_INCLUDE_HOSTNAME=true

METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
METRICS_NAMESPACE=clickhouse_llm

TRACING_ENABLED=false
TRACING_SAMPLE_RATE=0.1
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════

API_KEY_ROTATION_DAYS=90
API_KEY_ENCRYPTION=true
API_KEY_STORAGE=env

SECRETS_BACKEND=env
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_NAMESPACE=

AWS_SECRETS_REGION=us-east-1
AWS_SECRETS_PREFIX=clickhouse-llm/

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ENABLED=false
CORS_ORIGINS=*

# ═══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════

FEATURE_EMBEDDINGS=true
FEATURE_LLM_CHAT=true
FEATURE_RAG=true
FEATURE_STREAMING=false
FEATURE_FUNCTION_CALLING=false
FEATURE_MINDSDB=true
FEATURE_MULTI_AGENT=true

EXPERIMENTAL_GPU_EMBEDDINGS=false
EXPERIMENTAL_QUANTIZATION=false
EXPERIMENTAL_BATCH_INFERENCE=false

# ═══════════════════════════════════════════════════════════════
# DEVELOPMENT & DEBUGGING
# ═══════════════════════════════════════════════════════════════

ENVIRONMENT=development
DEBUG=false
VERBOSE=false

TEST_MODE=false
TEST_MOCK_APIS=false
TEST_SKIP_SLOW=false
PYTEST_ARGS=-v -s

HOT_RELOAD=false
PROFILING_ENABLED=false
MEMORY_PROFILING=false

# ═══════════════════════════════════════════════════════════════
# PERFORMANCE TUNING
# ═══════════════════════════════════════════════════════════════

MAX_THREADS=16
THREAD_POOL_SIZE=10
ASYNCIO_DEBUG=false

MAX_MEMORY_MB=4096
MEMORY_LIMIT_PERCENTAGE=80

GC_ENABLED=true
GC_THRESHOLD_0=700
GC_THRESHOLD_1=10
GC_THRESHOLD_2=10

# ═══════════════════════════════════════════════════════════════
# AGENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════

SEARCH_AGENT_ENABLED=true
SEARCH_AGENT_EXPAND_QUERIES=true
SEARCH_AGENT_MAX_RESULTS=10

ANALYSIS_AGENT_ENABLED=true
ANALYSIS_AGENT_BATCH_SIZE=50

QA_AGENT_ENABLED=true
QA_AGENT_RETRIEVAL_TOP_K=3
QA_AGENT_MULTI_HOP=true
QA_AGENT_MAX_HOPS=3

# ═══════════════════════════════════════════════════════════════
# DOCKER & ORCHESTRATION
# ═══════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=clickhouse-llm
COMPOSE_FILE=docker-compose.yml
DOCKER_BUILDKIT=1

CLICKHOUSE_MEMORY=4g
CLICKHOUSE_CPUS=2
MINDSDB_MEMORY=2g
MINDSDB_CPUS=1
REDIS_MEMORY=512m
REDIS_CPUS=0.5

# ═══════════════════════════════════════════════════════════════
# MISC CONFIGURATION
# ═══════════════════════════════════════════════════════════════

TZ=UTC
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8

DATA_DIR=/var/lib/clickhouse-llm
MODELS_DIR=/var/lib/clickhouse-llm/models
CACHE_DIR=/var/cache/clickhouse-llm
LOGS_DIR=/var/log/clickhouse-llm

TEMP_DIR=/tmp/clickhouse-llm
TEMP_CLEANUP_INTERVAL=3600
